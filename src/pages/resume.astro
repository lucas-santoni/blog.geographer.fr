---
import '@fontsource/fira-sans/400.css'
import '@fontsource/fira-sans/600.css'
import '@fontsource/fira-sans/700.css'
import '../styles/styles.css'
import '../styles/resume.css'
import {
  AUTHOR,
  DEFAULT_LANG,
  GITHUB_URL,
  MAIL,
  MAIL_URL,
  SITENAME,
  SITE,
  SITE_URL,
} from '../config'

const title = `${SITENAME} — Resume`;
---

<!doctype html>
<html lang={DEFAULT_LANG}>
  <head>
    <meta charset="UTF-8" />
    <meta name="theme-color" content="#000000" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <script is:inline>
      (() => {
        try {
          const stored = localStorage.getItem('theme')
          const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches
          const theme = stored ?? (prefersDark ? 'dark' : 'light')
          document.documentElement.setAttribute('data-theme', theme)
        } catch {
          // localStorage unavailable; leave default (light).
        }
      })()
    </script>

    <meta name="author" content={AUTHOR} />
    <link rel="canonical" href={`${SITE_URL}/resume`} />
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <title>{title}</title>
  </head>
  <body class="resume-page">
    <div class="resume-wrapper">
      <div class="resume-intro">
        <div>
          <h1>Lucas Santoni</h1>
          <p class="meta">Software Engineer &amp; Tech Executive</p>
        </div>
      </div>

      <div class="resume-content">
        <section>
          <h2>WORK EXPERIENCE</h2>

          <section class="role-group">
            <h3>Cryptio</h3>
            <div class="role-history">
              <section>
                <p class="meta">Since 2026 — Principal Engineer, Strategic Technology Initiatives</p>
                <p>
                  Transitioned from CTO after the Series B to refocus on
                  hands-on engineering. Leading the Platform Team on
                  foundational projects centered on performance and
                  scalability. Driving the adoption of AI coding tools across
                  the engineering organization.
                </p>
              </section>

              <section>
                <p class="meta">2021–2026 — Chief Technical Officer</p>
                <p>
                  Joined at pre-seed to build the engineering organization and
                  the foundations of the product from scratch. Recruited
                  dozens of engineers, mentored ICs and middle managers,
                  structured teams and delivery as the company grew to 110+
                  people serving 450+ enterprises across 30+ countries,
                  including Circle, Laser Digital, and Consensys.
                </p>
                <p>
                  Took the product from MVP to millions in ARR and over $3T in
                  processed transaction volume. As a member of the leadership
                  team, supported the CEO on strategy and on the seed, Series
                  A, and $45M Series B rounds. Owned the company's SOC 1 and
                  SOC 2 audits with PwC.
                </p>
              </section>
            </div>
          </section>

          <section>
            <h3>Epitech</h3>
            <p class="meta">Since 2019 — Cybersecurity Teacher</p>
            <p>
              Teaching cybersecurity modules to engineering students
              (reverse engineering, binary exploitation, and web security)
              through lectures, hands-on labs, and CTF-style assignments.
            </p>
          </section>

          <section>
            <h3>Vente-Privee (now Veepee)</h3>
            <p class="meta">2018 — Software Engineer Intern</p>
            <p>
              Maintained open-source Go tool <a
                href="https://github.com/strike-team/influxdb-relay"
              >InfluxDB Relay</a> and contributed to a C++ driver for a
              robotic system for automated product photography.
            </p>
          </section>

          <section>
            <h3>Thales</h3>
            <p class="meta">2017 — Cybersecurity Engineer Intern</p>
            <p>
              Conducted research on deception applied to database security
              under the supervision of Nizar Kheir, PhD, and eventually filed <a
                href="https://patentscope.wipo.int/search/fr/detail.jsf?docId=EP243363815"
              >a patent</a>.
            </p>
          </section>

          <section>
            <h3>Freelance Work</h3>
            <p class="meta">Since 2017</p>
            <p>
              Collaborated with various clients, such as Sony Music. Worked
              on a wide range of projects, from OCR pipelines in Python to
              large scale web scraping in JavaScript.
            </p>
          </section>
        </section>

        <section>
          <h2>EDUCATION</h2>

          <section>
            <h3>Master's degree in Information Technology</h3>
            <p class="meta">Epitech Paris (France) — 2021</p>
          </section>

          <section>
            <h3>MSc in Computational Intelligence</h3>
            <p class="meta">University Of Kent (United Kingdom) — 2020</p>
          </section>

          <section>
            <h3>Certificate of Proficiency in English (C2)</h3>
            <p class="meta">University Of Cambridge — 2015</p>
          </section>
        </section>

        <section>
          <h2>SKILLS</h2>

          <section>
            <h3>Engineering</h3>
            <p>
              Comfortable across the stack and across paradigms. Strong bias
              for picking the right tool for the problem, rather than
              defending a familiar language or framework.
            </p>
          </section>

          <section>
            <h3>Leadership &amp; Delivery</h3>
            <p>
              Hired and mentored dozens of engineers and middle managers.
              Structured teams, processes, and delivery from a single developer
              to multiple autonomous squads. Comfortable owning roadmap and
              stakeholder communication alongside technical decisions.
            </p>
          </section>

          <section>
            <h3>Computer Security</h3>
            <p>
              Self-taught foundations in reverse engineering, binary
              exploitation, and web security. Years of CTFs paired with
              enterprise security work: compliance, audits, and operations.
            </p>
          </section>

          <section>
            <h3>Languages &amp; Communication</h3>
            <p>
              Native French, fluent English. At ease with public
              speaking and technical writing in either language.
            </p>
          </section>
        </section>

        <section>
          <h2>EXTRACURRICULAR</h2>

          <section>
            <h3>PoC</h3>
            <p class="meta">2018 — Student Organization Co-Founder</p>
            <p>
              Co-founded <a href="https://poc-innovation.fr/">PoC</a> and led
              its cybersecurity department for two years. Gave dozens of talks
              and trainings, organized
              <a href="/piscine-poc-2019">
                a cybersecurity bootcamp
              </a>.
            </p>
          </section>
        </section>

        <section>
          <h2>CONTACT</h2>

          <ul class="contact">
            <li>🌍 Visit <a href={SITE_URL}>{SITE}</a></li>
            <li>📨 Write at <a href={MAIL_URL}>{MAIL}</a></li>
            <li>📜 See code on <a href={GITHUB_URL}>GitHub Profile</a></li>
          </ul>

          <p class="meta resume-updated">Updated May 2026</p>
        </section>
      </div>

      <div class="resume-footer">
        <div class="resume-live">
          <p>
            🖨️ <button type="button" id="print-button" class="print-link">Use the built-in print functionality of your browser or click this to get a clean A4 paper or a PDF.</button>.
          </p>
          <button class="theme-toggle" type="button" aria-label="Toggle theme">
            <span class="theme-toggle-dark" aria-hidden="true">🌙</span>
            <span class="theme-toggle-light" aria-hidden="true">☀️</span>
          </button>
        </div>

        <div class="resume-print">
          <p>
            🖥️ This resume is made for the web! Please, visit the live version
            at lucas.zip/resume .
          </p>
        </div>
      </div>
    </div>
    <script>
      document
        .getElementById('print-button')
        ?.addEventListener('click', () => window.print())

      const toggle = document.querySelector<HTMLButtonElement>('.theme-toggle')
      toggle?.addEventListener('click', () => {
        const current = document.documentElement.getAttribute('data-theme')
        const next = current === 'dark' ? 'light' : 'dark'
        document.documentElement.setAttribute('data-theme', next)
        try {
          localStorage.setItem('theme', next)
        } catch {
          // localStorage unavailable; toggle still works for the session.
        }
      })
    </script>
  </body>
</html>
