---
import { getCollection, getEntry, render } from 'astro:content';
import Base from '../layouts/Base.astro';
import { formatDate } from '../utils/formatDate';

const posts = (await getCollection('posts')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const page = await getEntry('pages', 'posts');
const { Content } = page ? await render(page) : { Content: null };
const title = page?.data.title ?? 'All blog posts';
---

<Base title={title} slug="posts">
  <div class="listing content">
    <h1>{title}</h1>

    <dl>
      {
        posts.map((post) => (
          <div class="listing-entry">
            <dt>{formatDate(post.data.date)}</dt>
            <dd><a href={`/${post.data.slug}`} set:html={post.data.title} /></dd>
          </div>
        ))
      }
    </dl>

    {Content && <Content />}

    <p><a href="/">← Back to the index</a></p>
  </div>
</Base>
