---
type Heading = { depth: number; slug: string; text: string }
type Props = { headings: Heading[] }

const { headings } = Astro.props
const items = headings.filter((h) => h.depth === 2)
const shouldRender = items.length >= 3;
---

{shouldRender && (
  <>
    <nav class="outline" aria-label="Article outline" data-outline id="article-outline">
      <p class="outline-title">Contents</p>
      <ol class="outline-list">
        {items.map((h) => (
          <li class:list={['outline-item', `outline-depth-${h.depth}`]} data-outline-item={h.slug}>
            <a href={`#${h.slug}`} data-outline-link>{h.text}</a>
          </li>
        ))}
      </ol>
    </nav>
    <button
      type="button"
      class="outline-toggle"
      aria-label="Toggle article outline"
      aria-expanded="false"
      aria-controls="article-outline"
      data-outline-toggle
    >
      <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" focusable="false">
        <path
          fill="currentColor"
          d="M4 6h12v2H4zM4 11h16v2H4zM4 16h10v2H4z"
        />
      </svg>
    </button>
  </>
)}

<script>
  type Cleanup = () => void

  function init(): Cleanup | undefined {
    const outline = document.querySelector<HTMLElement>('[data-outline]')
    const toggle = document.querySelector<HTMLButtonElement>('[data-outline-toggle]')
    if (!outline || !toggle) return

    const items = Array.from(
      outline.querySelectorAll<HTMLElement>('[data-outline-item]'),
    )
    const linkBySlug = new Map<string, HTMLAnchorElement>()
    for (const item of items) {
      const slug = item.dataset.outlineItem
      const link = item.querySelector<HTMLAnchorElement>('a')
      if (slug && link) linkBySlug.set(slug, link)
    }

    const headings = items
      .map((item) => {
        const slug = item.dataset.outlineItem
        return slug ? document.getElementById(slug) : null
      })
      .filter((el): el is HTMLElement => el !== null)

    let activeSlug: string | null = null

    function setActive(slug: string | null) {
      if (slug === activeSlug) return
      activeSlug = slug
      for (const item of items) {
        const isActive = item.dataset.outlineItem === slug
        item.classList.toggle('is-active', isActive)
      }
    }

    function updateActive() {
      if (headings.length === 0) return
      const threshold = Math.max(80, window.innerHeight * 0.2)
      let current: string | null = null
      for (const h of headings) {
        if (h.getBoundingClientRect().top <= threshold) {
          current = h.id
        } else {
          break
        }
      }
      // Near the bottom, force-activate the last heading (handles short final sections).
      if (
        window.innerHeight + window.scrollY >=
        document.documentElement.scrollHeight - 4
      ) {
        current = headings[headings.length - 1]!.id
      }
      setActive(current)
    }

    let rafId: number | null = null
    function onScroll() {
      if (rafId !== null) return
      rafId = window.requestAnimationFrame(() => {
        rafId = null
        updateActive()
      })
    }

    function openPanel() {
      outline!.setAttribute('data-open', 'true')
      toggle!.setAttribute('aria-expanded', 'true')
    }

    function closePanel() {
      outline!.removeAttribute('data-open')
      toggle!.setAttribute('aria-expanded', 'false')
    }

    function isOpen() {
      return outline!.getAttribute('data-open') === 'true'
    }

    function onToggleClick(event: MouseEvent) {
      event.stopPropagation()
      if (isOpen()) closePanel()
      else openPanel()
    }

    function onDocumentClick(event: MouseEvent) {
      if (!isOpen()) return
      const target = event.target
      if (!(target instanceof Node)) return
      if (outline!.contains(target) || toggle!.contains(target)) return
      closePanel()
    }

    function onLinkClick(event: MouseEvent) {
      const target = event.target
      if (!(target instanceof Element)) return
      const link = target.closest<HTMLAnchorElement>('[data-outline-link]')
      if (!link) return
      const hash = link.getAttribute('href')?.slice(1)
      const heading = hash ? document.getElementById(hash) : null
      if (heading) {
        event.preventDefault()
        heading.scrollIntoView({ behavior: 'smooth', block: 'start' })
        history.replaceState(null, '', `#${hash}`)
      }
      closePanel()
    }

    function onKeyDown(event: KeyboardEvent) {
      if (event.key === 'Escape' && isOpen()) {
        closePanel()
        toggle!.focus()
      }
    }

    const footer = document.querySelector<HTMLElement>('.footer')
    let footerObserver: IntersectionObserver | null = null
    if (footer) {
      footerObserver = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            toggle!.classList.toggle('is-hidden', entry.isIntersecting)
            if (entry.isIntersecting && isOpen()) closePanel()
          }
        },
        { rootMargin: '0px' },
      )
      footerObserver.observe(footer)
    }

    toggle.addEventListener('click', onToggleClick)
    document.addEventListener('click', onDocumentClick)
    outline.addEventListener('click', onLinkClick)
    document.addEventListener('keydown', onKeyDown)
    window.addEventListener('scroll', onScroll, { passive: true })
    window.addEventListener('resize', onScroll, { passive: true })

    updateActive()

    return () => {
      toggle.removeEventListener('click', onToggleClick)
      document.removeEventListener('click', onDocumentClick)
      outline.removeEventListener('click', onLinkClick)
      document.removeEventListener('keydown', onKeyDown)
      window.removeEventListener('scroll', onScroll)
      window.removeEventListener('resize', onScroll)
      footerObserver?.disconnect()
      if (rafId !== null) window.cancelAnimationFrame(rafId)
    }
  }

  let cleanup: Cleanup | undefined

  function setup() {
    cleanup?.()
    cleanup = init()
  }

  document.addEventListener('astro:page-load', setup)
  document.addEventListener('astro:before-swap', () => {
    cleanup?.()
    cleanup = undefined
  })
</script>
